# Get a free key at https://www.themoviedb.org/settings/api
# Use the "API Key (v3 auth)" value — a ~32 character string.
# Do NOT use the application UUID, OAuth client id, or "API Read Access Token" unless it starts with eyJ.
VITE_TMDB_API_KEY=your_tmdb_v3_api_key_here

# Countdown before the lotto spin (seconds). Default: 10
# VITE_COUNTDOWN_SECONDS=10

# Optional: reliable TURN for strict networks (free at https://www.metered.ca/tools/openrelay/)
# VITE_METERED_TURN_DOMAIN=yourapp.metered.live
# VITE_METERED_TURN_API_KEY=your_metered_api_key

# Optional: custom TURN server (overrides defaults above)
# VITE_TURN_URLS=turn:your-turn.example:3478,turns:your-turn.example:5349
# VITE_TURN_USERNAME=username
# VITE_TURN_CREDENTIAL=password
